# ============================================
# MSPclaw configuration
# Copy this file to `.env` and edit the values.
# ============================================

# --- LLM provider (server-side only — agents never need a key) ---
# Pick ONE provider. Default = openai with gpt-4o-mini (cheap + fast).
MSPCLAW_LLM_PROVIDER=openai             # openai | gemini | anthropic

# OpenAI (default)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Google Gemini (alternative)
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# Anthropic Claude (alternative)
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-haiku-4-5

# --- Server ---
# v0.1 uses SQLite — file is created automatically. Postgres comes in v1.0.
# MSPCLAW_DB_URL=sqlite:///mspclaw.db
MSPCLAW_HOST=0.0.0.0
MSPCLAW_PORT=8080

# --- Agent (client-side) ---
# Point this at your MSP server. Use the LAN IP of the Mac mini.
MSPCLAW_SERVER_URL=ws://localhost:8080/ws/agent
MSPCLAW_AGENT_TOKEN=                     # shared secret — auth comes in v1.0
MSPCLAW_TENANT_ID=default

# --- End-user CLI (client-side) ---
MSPCLAW_API_URL=http://localhost:8080

# --- Safety ---
MSPCLAW_REQUIRE_YES_GATE=true
MSPCLAW_MAX_ITERATIONS=12
