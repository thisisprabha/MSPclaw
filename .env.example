# --- LLM ---
LLM_BACKEND=gemini                       # gemini | ollama
GEMINI_API_KEY=                          # https://aistudio.google.com/apikey
GEMINI_MODEL=gemini-3.1-flash-lite-preview
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:latest

# --- Server ---
MSPCLAW_DB_URL=postgresql://mspclaw:mspclaw@localhost:5432/mspclaw
MSPCLAW_HOST=0.0.0.0
MSPCLAW_PORT=8080
MSPCLAW_WS_PATH=/ws/agent

# --- Agent (client side) ---
MSPCLAW_SERVER_URL=ws://localhost:8080/ws/agent
MSPCLAW_AGENT_TOKEN=                     # per-tenant shared secret (v1)
MSPCLAW_TENANT_ID=default

# --- Safety ---
MSPCLAW_REQUIRE_YES_GATE=true
MSPCLAW_MAX_ITERATIONS=12
MSPCLAW_EXECUTION_TIMEOUT_SEC=30
